<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Signup</title>

<style>
/* ===== Dark Theme ===== */
body{
    margin:0;
    font-family: Arial, Helvetica, sans-serif;
    background: linear-gradient(135deg,#141e30,#243b55);
    height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    color:white;
}

.container{
    background:#111;
    padding:40px;
    width:340px;
    border-radius:12px;
    box-shadow:0 0 20px rgba(0,0,0,0.7);
}

h2{
    text-align:center;
    margin-bottom:25px;
}

input{
    width:100%;
    padding:12px;
    margin:10px 0;
    border:none;
    border-radius:6px;
    background:#222;
    color:white;
    outline:none;
}

input:focus{
    border:1px solid #00ffb3;
}

button{
    width:100%;
    padding:12px;
    margin-top:15px;
    border:none;
    border-radius:6px;
    background:#00ffb3;
    color:black;
    font-size:16px;
    cursor:pointer;
    transition:0.3s;
}

button:hover{
    background:#00c896;
}

p{
    text-align:center;
    margin-top:15px;
}

a{
    color:#00ffb3;
    text-decoration:none;
}
</style>
</head>

<body>

<div class="container">
    <h2>Create Account</h2>

    <form action="/signup" method="post">
        <input type="text" placeholder="username" name="username">
        <input type="email" placeholder="Email" name="email">
        <input type="password" placeholder="Password" name="password" required>
        <button type="submit">Signup</button>
    </form>

    <p>Already have an account?
        <a href="/">Login</a>
    </p>
</div>

</body>
</html>